// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  CUSTOMER
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  BLOCKED
}

enum screenType {
  STANDARD
  VIP
  IMAX
  THREE_D
}

enum SeatType {
  REGULAR
  PREMIUM
  VIP
  RECLINER
  COUPLE
}

enum SeatStatus {
  AVAILABLE
  BLOCKED
  MAINTENANCE
}

enum MovieStatus {
  COMING_SOON
  NOW_SHOWING
  ARCHIVED
}

enum PricingType {
  FIXED
  PERCENTAGE
}

enum BookingStatus {
  PENDING
  RESERVED
  CONFIRMED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum BookingSource {
  WEB
  MOBILE
  COUNTER
}

enum ShowSeatStatus {
  AVAILABLE
  RESERVED
  BOOKED
  BLOCKED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  JAZZCASH
  EASYPAISA
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ShowStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum CouponType {
  FIXED
  PERCENTAGE
}

enum NotificationType {
  EMAIL
  SMS
  PUSH
}

model User {
  id String @id @default(uuid())

  firstName String
  lastName  String?

  email String  @unique @db.VarChar(50)
  phone String? @unique @db.VarChar(13)

  passwordHash String

  role   UserRole
  status UserStatus @default(PENDING)

  emailVerified Boolean @default(false)

  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?

  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bookings Booking[]

  createdShows Show[] @relation("ShowCreator")

  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  couponUsages  CouponUsage[]
}

model RefreshToken {
  id        String @id @default(cuid())
  tokenHash String @unique
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  expiresAt DateTime
  revoked   Boolean  @default(false)

  ipHash    String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  role         UserRole
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([role, permissionId])
}

model Cinema {
  id String @id @default(uuid())

  name    String
  address String
  slug    String @unique

  city    String?
  country String?

  phone String?
  email String?

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  screens screen[]
}

model screen {
  id String @id @default(uuid())

  cinemaId String

  name String
  slug String @unique

  type screenType

  capacity Int

  isActive Boolean @default(true)

  cinema Cinema @relation(fields: [cinemaId], references: [id])

  seats Seat[]

  shows Show[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Seat {
  id String @id @default(uuid())

  screenId String

  rowLabel   String
  seatNumber Int

  seatType SeatType

  status SeatStatus @default(AVAILABLE)

  screen screen @relation(fields: [screenId], references: [id])

  bookingSeats BookingSeat[]
  showSeats    ShowSeat[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([screenId, rowLabel, seatNumber])
}

model Movie {
  id String @id @default(uuid())

  title String
  slug  String @unique

  description String?

  durationMinutes Int

  releaseDate DateTime?

  language String

  ageRestriction Int?

  trailerUrl String?

  posterUrl String?

  bannerUrl String?

  status MovieStatus

  genres MovieGenre[]

  shows Show[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  casts     Cast[]
}

model Genre {
  id String @id @default(uuid())

  name String @unique
  slug String @unique

  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movies MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String

  movie Movie @relation(fields: [movieId], references: [id])
  genre Genre @relation(fields: [genreId], references: [id])

  @@id([movieId, genreId])
}

model Cast {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?
  role      String
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([movieId, name])
}

model Show {
  id String @id @default(uuid())

  movieId String

  screenId String

  startTime DateTime

  endTime DateTime

  cleaningMinutes Int      @default(15)
  occupiedUntil   DateTime

  status ShowStatus @default(SCHEDULED)

  createdById String

  movie Movie @relation(fields: [movieId], references: [id])

  screen screen @relation(fields: [screenId], references: [id])

  createdBy User @relation("ShowCreator", fields: [createdById], references: [id])

  bookings Booking[]

  pricingRules PricingRule[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  showSeats    ShowSeat[]
  bookingSeats BookingSeat[]

  @@index([screenId, startTime])
}

model PricingRule {
  id String @id @default(uuid())

  showId String

  seatType SeatType?

  amount Decimal @db.Decimal(10, 2)

  type PricingType

  show Show @relation(fields: [showId], references: [id])

  @@unique([showId, seatType])
}

model Booking {
  id String @id @default(uuid())

  bookingNumber String @unique

  userId String

  showId String

  couponId String?

  totalAmount Decimal @db.Decimal(10, 2)

  discountAmount Decimal @db.Decimal(10, 2)

  finalAmount Decimal @db.Decimal(10, 2)

  status BookingStatus

  source BookingSource @default(WEB)

  expiresAt DateTime?

  bookedAt DateTime?

  movieTitle    String
  screenName    String
  cinemaName    String
  showStartTime DateTime

  user User @relation(fields: [userId], references: [id])

  show Show @relation(fields: [showId], references: [id])

  coupon Coupon? @relation(fields: [couponId], references: [id])

  seats BookingSeat[]

  tickets Ticket[]

  payments Payment[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  showSeats    ShowSeat[]
  couponUsages CouponUsage[]

  @@index([userId])
  @@index([showId])
  @@index([status])
}

model BookingSeat {
  id String @id @default(uuid())

  bookingId String

  showId    String
  seatId    String
  seatLabel String
  seatType  SeatType

  price Decimal @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id])
  show    Show    @relation(fields: [showId], references: [id])
  seat    Seat    @relation(fields: [seatId], references: [id])

  tickets Ticket[]

  @@unique([bookingId, seatId])
}

model ShowSeat {
  showId        String
  seatId        String
  show          Show           @relation(fields: [showId], references: [id])
  seat          Seat           @relation(fields: [seatId], references: [id])
  status        ShowSeatStatus
  reservedUntil DateTime?
  bookingId     String?
  booking       Booking?       @relation(fields: [bookingId], references: [id])

  @@id([showId, seatId])
}

model Ticket {
  id            String      @id @default(uuid())
  bookingSeatId String
  bookingSeat   BookingSeat @relation(fields: [bookingSeatId], references: [id])

  bookingId String

  ticketNumber String @unique

  qrCode String @unique

  status TicketStatus @default(ACTIVE)

  checkedInAt DateTime?

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Payment {
  id String @id @default(uuid())

  bookingId String

  provider PaymentProvider @default(CASH)

  transactionId String?

  amount          Decimal   @db.Decimal(10, 2)
  gatewayResponse Json?
  failureReason   String?
  paidAt          DateTime?

  status PaymentStatus

  booking Booking @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
  refunds   Refund[]

  @@index([bookingId])
  @@index([status])
}

model Refund {
  id        String  @id @default(uuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id])
  bookingId String

  amount Decimal @db.Decimal(10, 2)

  reason String?

  status RefundStatus

  processedAt DateTime?

  createdAt DateTime @default(now())
}

model Coupon {
  id String @id @default(uuid())

  code String @unique

  type CouponType

  value Decimal @db.Decimal(10, 2)

  maxUses Int?

  usedCount Int @default(0)

  startsAt DateTime?

  expiresAt DateTime?

  isActive Boolean @default(true)

  bookings Booking[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  couponUsages CouponUsage[]
}

model CouponUsage {
  couponId  String
  bookingId String
  userId    String

  coupon  Coupon  @relation(fields: [couponId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  usedAt DateTime @default(now())

  @@unique([couponId, bookingId])
}

model Notification {
  id String @id @default(uuid())

  userId String

  type NotificationType

  subject String?

  message String

  sentAt DateTime?

  createdAt DateTime @default(now())
}

model AuditLog {
  id String @id @default(uuid())

  userId String

  action String

  entity String

  entityId String

  metadata Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Setting {
  key String @id

  value Json
}
