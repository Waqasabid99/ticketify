<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking Confirmed — <%= movieTitle %>
    </title>
</head>

<body style="margin:0;padding:0;background-color:#f4f4f7;font-family:Arial,Helvetica,sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f4f4f7;padding:40px 20px;">
        <tr>
            <td align="center">

                <table width="600" cellpadding="0" cellspacing="0" border="0"
                    style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.08);">

                    <!-- Header -->
                    <tr>
                        <td align="center" style="background-color:#111827;padding:32px 24px;">
                            <h1 style="margin:0;color:#ffffff;font-size:30px;font-weight:bold;">
                                🎬 Ticketify
                            </h1>
                            <p style="margin:8px 0 0;color:#9ca3af;font-size:14px;letter-spacing:0.5px;">
                                Your booking is confirmed!
                            </p>
                        </td>
                    </tr>

                    <!-- Success banner -->
                    <tr>
                        <td style="background:#16a34a;padding:16px 32px;text-align:center;">
                            <p style="margin:0;color:#ffffff;font-size:16px;font-weight:bold;">
                                ✅ Payment Successful — Enjoy the show!
                            </p>
                        </td>
                    </tr>

                    <!-- Greeting -->
                    <tr>
                        <td style="padding:36px 32px 0;">
                            <h2 style="margin:0 0 8px;color:#111827;font-size:22px;">
                                Hi <strong>
                                    <%= name %>
                                </strong> 👋
                            </h2>
                            <p style="margin:0;font-size:15px;line-height:1.7;color:#4b5563;">
                                Your booking has been confirmed. Below are your ticket details.
                                Present your QR code at the venue entrance.
                            </p>
                        </td>
                    </tr>

                    <!-- Movie & Booking Details -->
                    <tr>
                        <td style="padding:28px 32px 0;">
                            <table width="100%" cellpadding="0" cellspacing="0" border="0"
                                style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">

                                <!-- Section title -->
                                <tr>
                                    <td colspan="2" style="background:#111827;padding:12px 18px;">
                                        <p
                                            style="margin:0;color:#f9fafb;font-size:13px;font-weight:bold;text-transform:uppercase;letter-spacing:0.8px;">
                                            🎟 Booking Details
                                        </p>
                                    </td>
                                </tr>

                                <tr>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#6b7280;font-size:13px;width:40%;">
                                        Booking Number
                                    </td>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#111827;font-size:13px;font-weight:bold;">
                                        <%= bookingNumber %>
                                    </td>
                                </tr>

                                <tr>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#6b7280;font-size:13px;">
                                        Movie
                                    </td>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#111827;font-size:13px;font-weight:bold;">
                                        <%= movieTitle %>
                                    </td>
                                </tr>

                                <tr>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#6b7280;font-size:13px;">
                                        Cinema
                                    </td>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#111827;font-size:13px;">
                                        <%= cinemaName %>
                                    </td>
                                </tr>

                                <tr>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#6b7280;font-size:13px;">
                                        Screen
                                    </td>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#111827;font-size:13px;">
                                        <%= screenName %>
                                    </td>
                                </tr>

                                <tr>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#6b7280;font-size:13px;">
                                        Show Time
                                    </td>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#111827;font-size:13px;">
                                        <%= new Date(showStartTime).toLocaleString("en-US", { weekday: "long" ,
                                            year: "numeric" , month: "long" , day: "numeric" , hour: "2-digit" ,
                                            minute: "2-digit" , }) %>
                                    </td>
                                </tr>

                                <tr>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#6b7280;font-size:13px;">
                                        Seats
                                    </td>
                                    <td
                                        style="padding:14px 18px;border-bottom:1px solid #e5e7eb;color:#111827;font-size:13px;">
                                        <% if (seatLabels && seatLabels.length> 0) { %>
                                            <%= seatLabels.join(", ") %>
                                        <% } else { %>
                                            —
                                        <% } %>
                                    </td>
                                </tr>

                                <tr>
                                    <td style=" padding:14px 18px;color:#6b7280;font-size:13px;">
                                                Amount Paid
                                    </td>
                                    <td style="padding:14px 18px;color:#16a34a;font-size:14px;font-weight:bold;">
                                        PKR <%= Number(finalAmount).toLocaleString() %>
                                    </td>
                                </tr>

                            </table>
                        </td>
                    </tr>

                    <!-- Ticket Numbers -->
                    <tr>
                        <td style="padding:28px 32px 0;">
                            <table width="100%" cellpadding="0" cellspacing="0" border="0"
                                style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">

                                <tr>
                                    <td style="background:#111827;padding:12px 18px;">
                                        <p
                                            style="margin:0;color:#f9fafb;font-size:13px;font-weight:bold;text-transform:uppercase;letter-spacing:0.8px;">
                                            🎫 Your Tickets
                                        </p>
                                    </td>
                                </tr>

                                <% ticketNumbers.forEach(function(tn, i) { %>
                                    <tr>
                                        <td style="padding:12px 18px;color:#374151;font-size:13px;">
                                            🎟 <%= tn %>
                                        </td>
                                    </tr>
                                    <% }); %>

                            </table>
                        </td>
                    </tr>

                    <!-- QR Code Section -->
                    <tr>
                        <td style="padding:28px 32px 0;">
                            <table width="100%" cellpadding="0" cellspacing="0" border="0"
                                style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;overflow:hidden;">
                                <!-- Header -->
                                <tr>
                                    <td style="background:#1e40af;padding:12px 18px;">
                                        <p style="margin:0;color:#ffffff;font-size:13px;font-weight:bold;text-transform:uppercase;letter-spacing:0.8px;">
                                            📱 QR Code for Entry
                                        </p>
                                    </td>
                                </tr>
                                <!-- QR Image -->
                                <tr>
                                    <td align="center" style="padding:24px 18px 12px;">
                                        <img src="<%= qrCode %>"
                                            alt="Booking QR Code"
                                            width="200"
                                            height="200"
                                            style="display:block;border:6px solid #ffffff;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.12);" />
                                    </td>
                                </tr>
                                <!-- Caption -->
                                <tr>
                                    <td align="center" style="padding:0 18px 20px;">
                                        <p style="margin:0;color:#1e40af;font-size:13px;font-weight:bold;">
                                            Scan at the venue gate
                                        </p>
                                        <p style="margin:6px 0 0;color:#3b82f6;font-size:12px;line-height:1.6;">
                                            Your tickets share a single QR code — present it once per entry.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Important Notice -->
                    <tr>
                        <td style="padding:24px 32px 0;">
                            <hr style="margin:0 0 20px;border:none;border-top:1px solid #e5e7eb;">
                            <p style="margin:0;font-size:13px;color:#6b7280;line-height:1.7;">
                                ⚠️ <strong>Please arrive 15 minutes before the show.</strong>
                                Tickets are non-transferable and must match a valid ID.
                                For cancellations or refunds, visit your booking history in the app.
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center" style="background:#f9fafb;padding:24px;margin-top:32px;">
                            <p style="margin:0;font-size:12px;color:#9ca3af;">
                                © <%= currentYear %> Ticketify. All rights reserved.
                            </p>
                            <p style="margin-top:8px;font-size:12px;color:#9ca3af;">
                                This is an automated email. Please do not reply.
                            </p>
                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>

</html>